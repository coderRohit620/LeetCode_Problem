{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Run (Clean Output)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${fileDirname}",
            "stopAtEntry": false,

            "externalConsole": false,
            "console": "integratedTerminal",

            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",

            "preLaunchTask": "C/C++: g++ build active file",

            "logging": {
                "engineLogging": false,
                "trace": false,
                "traceResponse": false
            }
        }
    ]
}